# Copy this file to `.env` and fill in your own keys. `.env` is gitignored —
# never commit it. Each person who runs caddie-ai needs their own keys.

# Required for AI scoring & drafting — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides
# ANTHROPIC_MODEL=claude-sonnet-4-6      # drafting model
# FIT_MODEL=claude-haiku-4-5             # fit scorer (fast/cheap)

# Optional board API keys (only needed for these specific boards)
# ADZUNA_APP_ID=...                      # free: https://developer.adzuna.com
# ADZUNA_APP_KEY=...
# WEB3_CAREER_TOKEN=...                  # https://web3.career/web3-jobs-api
